# Copy this file as .env and fill in your values

# Secret token for the OpenClaw gateway.
# Anyone with access to your server IP can use your APIs without this token — make it long and random.
# Validation: required, 32+ characters, letters/numbers/hyphens only. Do not use shell metacharacters.
# Generate with PowerShell:           [guid]::NewGuid().ToString() + [guid]::NewGuid().ToString()
# Generate with CMD:                  powershell -command "[guid]::NewGuid().ToString() + [guid]::NewGuid().ToString()"
# Generate with Git Bash/Linux/macOS: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Official OpenClaw container tag to deploy.
# Keep pinned for reproducibility. Update with:
#   scripts/update-openclaw-version.sh
OPENCLAW_VERSION=2026.4.24

# IP address of your NAS.
# Validation: required, must be a valid IPv4 address.
NAS_IP=

# Raw OpenClaw gateway bind address.
# Keep this on 127.0.0.1 so the browser enters through the HTTPS Nginx proxy only.
# Never port-forward this port from the router.
OPENCLAW_HOST_BIND=127.0.0.1

# Access mode. Browser access is HTTPS-only in this deployment.
OPENCLAW_HTTPS_MODE=local

# Host IP where bundled Nginx publishes HTTPS.
# Usually this is your NAS LAN IP.
OPENCLAW_PROXY_BIND=

# Host port for bundled Nginx HTTPS.
# Default avoids Synology/NPM ports that often already use 443.
OPENCLAW_HTTPS_PORT=8443

# Explicit HTTPS browser origin allowed to open the OpenClaw Control UI.
# install.sh fills this automatically, for example: ["https://192.168.1.50:8443"]
OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS=

# Container timezone
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Madrid

# =============================================================================
# AI PROVIDERS — Fill in only the ones you plan to use (one is enough).
# If you plan to configure OpenAI OAuth/device-code later, setup warns but does not block by default.
# Use ./setup.sh --strict-providers to require at least one API key during setup.
# =============================================================================

# Google Gemini — Generous free tier
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter — Access to many models, includes :free models
# Get key: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Anthropic (Claude) — Pay-per-use
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (GPT) — Pay-per-use
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Mistral AI — Free tier available
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Groq — Very generous free tier (high speed)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Cohere — Free tier available
# Get key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Ollama (local) — No key needed, just the server URL
# Install: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
